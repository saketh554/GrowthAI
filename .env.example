# Copy to .env and fill in. Never commit .env.

# OpenAI (LLM + vision + embeddings)
OPENAI_API_KEY=sk-...

# Model config (swappable)
JUDGE_MODEL=gpt-4o
EXTRACTION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.30

# Upload controls
UPLOAD_MAX_FILE_SIZE_MB=15
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.txt

# Storage paths (persistent disk in deployment)
SQLITE_PATH=./data/northwind.db
CHROMA_PATH=./data/chroma
POLICIES_DIR=./data/policies
SUBMISSIONS_DIR=./data/submissions
